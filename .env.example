# =====================================================================
# Asset Foundry — Variables de Entorno para Producción
# =====================================================================
# Copia este archivo como ".env" y rellena los valores.
#   cp .env.example .env
#
# En Railway.app, estas variables se configuran desde el panel web:
#   https://railway.app → Tu Proyecto → Variables
# =====================================================================

# Dominio público asignado por la plataforma de hosting.
# Railway lo asigna automáticamente (ej: asset-foundry-production.up.railway.app)
# Si tienes dominio propio, ponlo aquí (ej: assetfoundry.com)
DOMAIN=tu-app.up.railway.app

# Puerto de entrada (Railway usa la variable PORT automáticamente)
PORT=80
